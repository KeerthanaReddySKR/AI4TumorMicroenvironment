# ============================================================
# 15. SUMMARY + SAVE
# ============================================================

print("\nCell Composition (%):\n", adata.obs['cell_type'].value_counts(normalize=True)*100)

adata.write("data/processed/adata_final.h5ad")

print("\n PIPELINE Sucessfully COMPLETED ")
