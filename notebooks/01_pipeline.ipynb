import scanpy as sc
import scanpy.external as sce
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, classification_report

import torch
import torch.nn as nn
import torch.optim as optim
import os

# ============================================================
# VERSION INFO
# ============================================================

print("Pipeline Version: V8 | Publication Ready")

# ============================================================
# 0. REPRODUCIBILITY + SETTINGS
# ============================================================

np.random.seed(42)
torch.manual_seed(42)

sc.settings.verbosity = 3
sc.logging.print_header()

os.makedirs("results/figures", exist_ok=True)
os.makedirs("results/models", exist_ok=True)

# ============================================================
# 1. LOAD DATA
# ============================================================

adata = sc.read_h5ad("data/raw/GSE131907.h5ad")
adata.var_names_make_unique()

# ============================================================
# 2. DATA AUDIT
# ============================================================

print("Cells:", adata.n_obs)
print("Genes:", adata.n_vars)
print("Metadata:", adata.obs.columns.tolist())
print("Gene format sample:", adata.var_names[:10])

# ============================================================
# 3. QC + PREPROCESSING
# ============================================================

adata.var['mt'] = adata.var_names.str.startswith('MT-')
sc.pp.calculate_qc_metrics(adata, qc_vars=['mt'], inplace=True)

adata = adata[adata.obs.pct_counts_mt < 5, :]
sc.pp.filter_genes(adata, min_cells=3)

sc.pp.normalize_total(adata, target_sum=1e4)
sc.pp.log1p(adata)

sc.pp.highly_variable_genes(adata, n_top_genes=2000)
adata = adata[:, adata.var.highly_variable]

sc.pp.scale(adata)

# ============================================================
# 4. BATCH EFFECT CORRECTION
# ============================================================

if "batch" in adata.obs.columns:
    print("Applying Harmony batch correction...")
    sce.pp.harmony_integrate(adata, 'batch')

# ============================================================
# 5. PCA + UMAP + CLUSTERING
# ============================================================

sc.tl.pca(adata)
sc.pp.neighbors(adata)
sc.tl.umap(adata)
sc.tl.leiden(adata)

# ============================================================
# 6. MARKER DETECTION
# ============================================================

sc.tl.rank_genes_groups(adata, 'leiden', method='wilcoxon')

marker_dict = {
    "T_cells": ["CD3D", "CD3E", "CD2", "TRAC"],
    "B_cells": ["MS4A1", "CD79A"],
    "Macrophages": ["CD68", "CD163", "CSF1R"],
    "Tumor_epithelial": ["EPCAM", "KRT8", "KRT18", "KRT19"],
    "Fibroblasts": ["COL1A1", "COL1A2"],
    "Endothelial": ["PECAM1", "VWF"]
}

# ============================================================
# 7. ROBUST ANNOTATION
# ============================================================

def score_celltype(top_genes, marker_dict):
    scores = {
        celltype: len(set(top_genes).intersection(markers))
        for celltype, markers in marker_dict.items()
    }
    return max(scores, key=scores.get)

cluster_annotations = {}

for cluster in adata.obs['leiden'].unique():
    df = sc.get.rank_genes_groups_df(adata, group=cluster)
    df = df[df['pvals_adj'] < 0.05]
    top_genes = df['names'][:20].tolist()

    cluster_annotations[cluster] = score_celltype(top_genes, marker_dict)

adata.obs['cell_type'] = adata.obs['leiden'].map(cluster_annotations)

# ============================================================
# 8. CATEGORY LABEL
# ============================================================

def categorize(x):
    if x in ["T_cells", "B_cells", "Macrophages"]:
        return "Immune"
    elif x == "Tumor_epithelial":
        return "Tumor"
    else:
        return "Stromal"

adata.obs['category'] = adata.obs['cell_type'].apply(categorize)

# ============================================================
# 9. AUTOENCODER
# ============================================================

class Autoencoder(nn.Module):
    def __init__(self, input_dim):
        super().__init__()
        self.encoder = nn.Sequential(
            nn.Linear(input_dim, 128),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(128, 32)
        )
        self.decoder = nn.Sequential(
            nn.Linear(32, 128),
            nn.ReLU(),
            nn.Linear(128, input_dim)
        )

    def forward(self, x):
        return self.decoder(self.encoder(x))

X_tensor = torch.tensor(adata.X.toarray(), dtype=torch.float32)

ae = Autoencoder(X_tensor.shape[1])
optimizer = optim.Adam(ae.parameters(), lr=1e-3)
loss_fn = nn.MSELoss()

for epoch in range(30):
    optimizer.zero_grad()
    loss = loss_fn(ae(X_tensor), X_tensor)
    loss.backward()
    optimizer.step()

latent = ae.encoder(X_tensor).detach().numpy()
torch.save(ae.state_dict(), "results/models/autoencoder.pth")

# ============================================================
# 10. ML COMPARISON
# ============================================================

y = adata.obs['category']
X_pca = adata.obsm['X_pca']

X_train_pca, X_test_pca, y_train, y_test = train_test_split(
    X_pca, y, test_size=0.2, stratify=y, random_state=42
)

X_train_lat, X_test_lat, _, _ = train_test_split(
    latent, y, test_size=0.2, stratify=y, random_state=42
)

rf_pca = RandomForestClassifier(n_estimators=100).fit(X_train_pca, y_train)
rf_lat = RandomForestClassifier(n_estimators=100).fit(X_train_lat, y_train)

pred_pca = rf_pca.predict(X_test_pca)
pred_lat = rf_lat.predict(X_test_lat)

acc_pca = accuracy_score(y_test, pred_pca)
acc_lat = accuracy_score(y_test, pred_lat)
improvement = acc_lat - acc_pca

with open("results/metrics.txt", "w") as f:
    f.write(f"PCA Accuracy: {acc_pca}\nLatent Accuracy: {acc_lat}\nImprovement: {improvement}\n")

print("RF PCA Accuracy:", acc_pca)
print("RF Latent Accuracy:", acc_lat)
print("Improvement:", improvement)

print("\nClassification Report:\n")
print(classification_report(y_test, pred_lat))

# ============================================================
# 11. PERFORMANCE FIGURE
# ============================================================

plt.figure()
plt.bar(["RF (PCA)", "RF (Latent)"], [acc_pca, acc_lat])
plt.title("Performance Comparison: PCA vs Latent Features")
plt.savefig("results/figures/model_comparison.png")
plt.show()

# ============================================================
# 12. NN CLASSIFIER
# ============================================================

labels = y.astype("category").cat.codes.values
X_train, X_test, y_train_idx, y_test_idx = train_test_split(
    latent, labels, test_size=0.2, stratify=labels, random_state=42
)

clf = nn.Sequential(nn.Linear(latent.shape[1],64), nn.ReLU(), nn.Linear(64,len(np.unique(labels))))
opt = optim.Adam(clf.parameters())

for _ in range(30):
    opt.zero_grad()
    loss = nn.CrossEntropyLoss()(clf(torch.tensor(X_train).float()), torch.tensor(y_train_idx))
    loss.backward()
    opt.step()

print("NN Accuracy:", accuracy_score(y_test_idx, clf(torch.tensor(X_test).float()).argmax(1)))

# ============================================================
# 13. PSEUDOTIME
# ============================================================

root_idx = np.flatnonzero(adata.obs['cell_type'] == 'T_cells')
if len(root_idx) > 0:
    adata.uns['iroot'] = root_idx[0]

sc.tl.dpt(adata)

# ============================================================
# 14. OPTIONAL CELL-CELL INTERACTION 
